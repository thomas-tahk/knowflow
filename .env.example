# Copy to .env.local for local dev, and set the same vars in Vercel for production.
# .env.local is gitignored — never commit real values.

# Anthropic key for AI diagram generation (server-side only).
ANTHROPIC_API_KEY=sk-ant-...

# Shared team password gate (production). Leave unset locally to skip the gate in dev.
APP_PASSWORD=choose-a-team-password

# Discord "incoming webhook" URL that in-app feedback posts to.
# Create it in Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# Supabase (shared diagram library). Service key is server-side only — never expose it to the client.
# Without these, storage transparently falls back to localStorage (fine for local dev).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
